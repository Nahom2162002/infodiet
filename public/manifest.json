{
  "manifest_version": 3,
  "name": "InfoDiet",
  "version": "1.0.0",
  "description": "Your brain deserves a healthy diet — track and manage your information consumption",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "InfoDietIcon-16x16.png",
      "32": "InfoDietIcon-32x32.png",
      "128": "InfoDietIcon-128x128.png"
    }
  },
  "icons": {
    "16": "InfoDietIcon-16x16.png",
    "32": "InfoDietIcon-32x32.png",
    "128": "InfoDietIcon-128x128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "webNavigation"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["index.html", "assets/*", "budget-exceeded.html"],
      "matches": ["<all_urls>"]
    }
  ]
}